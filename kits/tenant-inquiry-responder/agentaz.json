{
  "$schema": "./agentaz.schema.json",
  "version": "2.0.0",
  "last_reviewed": "2026-06-24",
  "agent_id": "tenant-inquiry-agent",
  "trust_level": "A2",
  "dna_pattern": "Escalation",
  "worst_case_action": "Drafts a wrong tenant reply, caught before send. Escalates emergencies; cannot send or commit.",
  "authority_boundary": "Answers tenant inquiries from listing/policy in Fair-Housing-compliant language; send/account tools absent.",
  "tags": [
    "real-estate",
    "tenant-support",
    "fair-housing",
    "read-only",
    "human-review"
  ],
  "tool_boundary": {
    "allowed_tools": [
      "read_listing",
      "read_policy",
      "draft_reply",
      "check_fair_housing",
      "route"
    ],
    "execution_tools_absent": true
  },
  "output_boundary": {
    "format": "structured_json",
    "never_emits": [
      "send",
      "commitment",
      "account_action"
    ],
    "fair_housing_compliant": true
  },
  "cost_boundary": {
    "max_usd_per_trace_loop": 0.2,
    "alert_threshold_usd": 0.14
  },
  "loop_boundary": {
    "max_reasoning_turns": 8
  },
  "human_handoff": {
    "triggers": [
      "emergency",
      "maintenance",
      "legal_or_discrimination_sensitive"
    ],
    "destination": "property_manager"
  },
  "audit": {
    "append_only": true,
    "logs": [
      "drafts",
      "routing"
    ]
  }
}
