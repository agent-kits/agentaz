{
  "$schema": "./agentaz.schema.json",
  "version": "2.0.0",
  "last_reviewed": "2026-06-24",
  "agent_id": "policy-coverage-agent",
  "trust_level": "A2",
  "dna_pattern": "Synthesis",
  "worst_case_action": "Gives a wrong coverage explanation for human review. Cannot determine coverage, approve/deny, or pay.",
  "authority_boundary": "Explains policy coverage with citations; determination/payment tools absent.",
  "tags": [
    "insurance",
    "coverage",
    "read-only",
    "human-review"
  ],
  "tool_boundary": {
    "allowed_tools": [
      "read_policy",
      "explain_coverage",
      "cite_clause",
      "flag_ambiguity"
    ],
    "execution_tools_absent": true
  },
  "output_boundary": {
    "format": "structured_json",
    "never_emits": [
      "coverage_determination",
      "approve",
      "deny",
      "payment"
    ]
  },
  "cost_boundary": {
    "max_usd_per_trace_loop": 0.22,
    "alert_threshold_usd": 0.15
  },
  "loop_boundary": {
    "max_reasoning_turns": 8
  },
  "human_handoff": {
    "triggers": [
      "ambiguous_clause",
      "edge_case",
      "low_confidence"
    ],
    "destination": "licensed_agent"
  },
  "audit": {
    "append_only": true,
    "logs": [
      "explanations",
      "citations"
    ]
  }
}
