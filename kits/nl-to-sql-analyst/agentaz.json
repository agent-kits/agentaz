{
  "$schema": "./agentaz.schema.json",
  "version": "2.0.0",
  "last_reviewed": "2026-06-24",
  "agent_id": "nl-to-sql-agent",
  "trust_level": "A1",
  "dna_pattern": "Research",
  "worst_case_action": "Returns wrong figures from a read-only query for human interpretation. Cannot modify data.",
  "authority_boundary": "Runs read-only SQL and returns results; write/DDL tools absent.",
  "tags": [
    "data-analysis",
    "nl-to-sql",
    "read-only",
    "analytics"
  ],
  "tool_boundary": {
    "allowed_tools": [
      "generate_sql",
      "run_readonly_query",
      "show_query",
      "summarize_result"
    ],
    "execution_tools_absent": true,
    "read_only": true
  },
  "output_boundary": {
    "format": "structured_json",
    "never_emits": [
      "insert",
      "update",
      "delete",
      "ddl"
    ]
  },
  "cost_boundary": {
    "max_usd_per_trace_loop": 0.25,
    "alert_threshold_usd": 0.16
  },
  "loop_boundary": {
    "max_reasoning_turns": 8
  },
  "human_handoff": {
    "triggers": [
      "ambiguous_question",
      "sensitive_table",
      "low_confidence"
    ],
    "destination": "data_team"
  },
  "audit": {
    "append_only": true,
    "logs": [
      "queries",
      "row_counts"
    ]
  }
}
